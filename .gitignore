
***

## .gitignore

```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Environments
.env
.venv
env/
venv/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# API Keys — never commit these
secrets.json
.secrets
kaggle.json

# Vector DB local storage
chroma_db/
chroma_reviews_db/
faiss_index/
*.faiss
*.index

# Large data files
*.csv
*.parquet
*.arrow
data/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
